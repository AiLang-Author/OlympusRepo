# OlympusRepo configuration template
# Copy to .env and fill in real values. Never commit .env.

# Database
OLYMPUSREPO_DB_NAME=olympusrepo
OLYMPUSREPO_DB_USER=olympus
OLYMPUSREPO_DB_PASS=change-me-to-a-strong-password
OLYMPUSREPO_DB_HOST=127.0.0.1
OLYMPUSREPO_DB_PORT=5432

# Server
OLYMPUSREPO_PORT=8000
OLYMPUSREPO_PUBLIC_URL=http://localhost:8000

# Object store — must be the same path for CLI and server
OLYMPUSREPO_OBJECTS_DIR=/absolute/path/to/objects

# Set to 1 when serving behind HTTPS
OLYMPUSREPO_COOKIE_SECURE=0

# Relay
OLYMPUSREPO_RELAY_ENABLED=0
OLYMPUSREPO_INSTANCE_NAME=my-instance
OLYMPUSREPO_RELAYS=http://localhost:9000

# Relay server (only if running olympusrelay)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OLYMPUSRELAY_SECRET=
