{% extends "base.html" %}
{% block title %}Settings &mdash; {{ repo.name }}{% endblock %}

{% block extra_css %}
<style>
    main {
        background:
            linear-gradient(to bottom, rgba(13,17,23,0.82), rgba(13,17,23,0.96)),
            url('/static/forge-room.png') center center / cover no-repeat fixed;
    }
</style>
{% endblock %}

{% block content %}
<div class="container" style="max-width:560px;">
    <div class="row-between" style="margin-bottom:24px;">
        <h1 style="margin-bottom:0;">Repository Settings</h1>
        <a href="/repo/{{ repo.name }}" class="btn">Back to Repo</a>
    </div>

    <div id="settings-error" class="flash flash-error" style="display:none;"></div>
    <div id="settings-success" class="flash flash-success" style="display:none;"></div>

    <div class="form-group">
        <label for="repo-desc">Description</label>
        <textarea id="repo-desc" placeholder="Repository description">{{ repo.description or '' }}</textarea>
    </div>

    <div class="form-group">
        <label for="repo-visibility">Visibility</label>
        <select id="repo-visibility">
            <option value="public" {% if repo.visibility == 'public' %}selected{% endif %}>Public — anyone can read</option>
            <option value="internal" {% if repo.visibility == 'internal' %}selected{% endif %}>Internal — logged-in users can read</option>
            <option value="private" {% if repo.visibility == 'private' %}selected{% endif %}>Private — only you and granted users</option>
        </select>
    </div>

    <div style="margin-top:24px;">
        <button id="save-settings-btn" class="btn btn-primary">Save Settings</button>
    </div>

    <div style="margin-top:24px;">
        <a href="/repo/{{ repo.name }}/access" class="btn">Manage Access Grants</a>
    </div>

    <div class="card" style="border-color:#da3633; margin-top:32px;">
        <h2 style="color:#f85149; margin-top:0;">Danger Zone</h2>
        <div class="row-between">
            <div>
                <strong>Delete this repository</strong>
                <div class="card-meta">This is permanent. All commits, files, branches, and mana will be deleted.</div>
            </div>
            <button id="delete-repo-btn" class="btn btn-danger">Delete Repository</button>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
(function() {
    var repoName = {{ repo.name | tojson }};
    var btn = document.getElementById('save-settings-btn');
    var errEl = document.getElementById('settings-error');
    var okEl = document.getElementById('settings-success');

    btn.addEventListener('click', async function() {
        errEl.style.display = 'none';
        okEl.style.display = 'none';

        var desc = document.getElementById('repo-desc').value;
        var vis = document.getElementById('repo-visibility').value;

        btn.disabled = true;
        btn.textContent = 'Saving...';

        try {
            var form = new FormData();
            form.append('description', desc);
            form.append('visibility', vis);

            var res = await fetch('/api/repos/' + encodeURIComponent(repoName) + '/settings', {
                method: 'POST',
                body: form
            });

            if (res.ok) {
                okEl.textContent = 'Settings updated successfully.';
                okEl.style.display = 'block';
            } else {
                var data = {};
                try { data = await res.json(); } catch(e) {}
                errEl.textContent = data.detail || 'Could not update settings.';
                errEl.style.display = 'block';
            }
        } catch(err) {
            errEl.textContent = 'Network error.';
            errEl.style.display = 'block';
        } finally {
            btn.disabled = false;
            btn.textContent = 'Save Settings';
        }
    });

    document.getElementById('delete-repo-btn').addEventListener('click', async function() {
        var repoName = {{ repo.name | tojson }};
        if (prompt('Type the repository name to confirm deletion:') !== repoName) {
            alert('Name did not match. Deletion cancelled.');
            return;
        }
        var res = await fetch('/api/repos/' + encodeURIComponent(repoName), {
            method: 'DELETE'
        });
        if (res.ok) {
            window.location = '/';
        } else {
            var data = {};
            try { data = await res.json(); } catch(e) {}
            alert(data.detail || 'Deletion failed.');
        }
    });
})();
</script>
{% endblock %}