{% extends "base.html" %}
{% block title %}New Repository &mdash; OlympusRepo{% endblock %}

{% block extra_css %}
<style>
    main {
        background:
            linear-gradient(to bottom, rgba(13,17,23,0.82), rgba(13,17,23,0.96)),
            url('/static/forge-room.png') center center / cover no-repeat fixed;
    }
</style>
{% endblock %}

{% block content %}
<div class="container" style="max-width:560px;">
    <h1>New Repository</h1>

    <div id="form-error" class="flash flash-error" style="display:none;"></div>

    <!-- STEP 1: Repo Details -->
    <div id="step-1">
        <div class="form-group">
            <label for="repo-name">Repository Name <span style="color:#8b949e;">*</span></label>
            <input type="text" id="repo-name" placeholder="my-project" autofocus
                   pattern="[a-zA-Z0-9_\-]+" title="Letters, numbers, hyphens, underscores only">
            <div style="font-size:0.8em; color:#8b949e; margin-top:4px;">
                Letters, numbers, hyphens, and underscores only.
            </div>
        </div>
    
        <div class="form-group">
            <label for="repo-desc">Description <span style="color:#8b949e;">(optional)</span></label>
            <input type="text" id="repo-desc" placeholder="What is this repo for?">
        </div>
    
        <div class="form-group">
            <label for="repo-visibility">Visibility</label>
            <select id="repo-visibility">
                <option value="public">Public — anyone can read</option>
                <option value="internal">Internal — logged-in users can read</option>
                <option value="private">Private — only you and granted users</option>
            </select>
        </div>
    
        <div class="row" style="margin-top:24px;">
            <button id="create-btn" class="btn btn-primary">Create Repository</button>
            <a href="/" class="btn">Cancel</a>
        </div>
    </div>

    <!-- STEP 2: Seed Files -->
    <div id="step-2" style="display:none;">
        <h2 style="margin-top:0;">Add Files to Your Repository</h2>
        <p style="color:#8b949e; font-size:0.9em; margin-bottom:16px;">Optional — you can also add files later from the repo page</p>
        
        <div id="upload-drop-zone" style="border: 2px dashed #30363d; padding: 48px 24px; text-align: center; border-radius: 6px; cursor: pointer; margin-bottom: 16px; background: rgba(22,27,34,0.5);">
            <span style="color: #c9d1d9; font-size: 1.1em;">Drag a folder here, or click to browse</span>
            <input type="file" id="folder-input" webkitdirectory multiple style="display:none;">
        </div>
        
        <div id="upload-preview" style="display:none; margin-bottom:16px;">
            <strong id="upload-count" style="display:block; margin-bottom:8px; color:#f0f6fc;"></strong>
            <div id="upload-list" class="mono" style="max-height:200px; overflow-y:auto; background:#0d1117; border:1px solid #30363d; border-radius:6px; padding:8px; font-size:0.85em; color:#8b949e;"></div>
        </div>
        
        <div class="form-group">
            <label for="commit-message">Commit Message</label>
            <input type="text" id="commit-message" value="Initial commit">
        </div>
        
        <div class="row" style="margin-top:24px;">
            <button id="upload-finish-btn" class="btn btn-primary" disabled>Upload &amp; Finish</button>
            <button id="skip-btn" class="btn">Skip — I'll add files later</button>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
(function() {
    var nameEl = document.getElementById('repo-name');
    var descEl = document.getElementById('repo-desc');
    var visEl  = document.getElementById('repo-visibility');
    var errEl  = document.getElementById('form-error');
    var btn    = document.getElementById('create-btn');
    var createdRepoName = null;
    
    var dropZone = document.getElementById('upload-drop-zone');
    var folderInput = document.getElementById('folder-input');
    var uploadPreview = document.getElementById('upload-preview');
    var uploadCount = document.getElementById('upload-count');
    var uploadList = document.getElementById('upload-list');
    var uploadFinishBtn = document.getElementById('upload-finish-btn');
    var skipBtn = document.getElementById('skip-btn');
    var commitMessage = document.getElementById('commit-message');
    var selectedFilteredFiles = [];

    // Sanitize name as user types: lowercase, replace spaces with hyphens
    nameEl.addEventListener('input', function() {
        var v = nameEl.value.replace(/\s+/g, '-').replace(/[^a-zA-Z0-9_\-]/g, '').replace(/[-_]+$/, '');
        if (v !== nameEl.value) nameEl.value = v;
    });

    async function doCreate() {
        errEl.style.display = 'none';

        var name = nameEl.value.trim();
        if (!name) {
            errEl.textContent = 'Repository name is required.';
            errEl.style.display = 'block';
            nameEl.focus();
            return;
        }
        if (!/^[a-zA-Z0-9_\-]+$/.test(name)) {
            errEl.textContent = 'Name can only contain letters, numbers, hyphens, and underscores.';
            errEl.style.display = 'block';
            nameEl.focus();
            return;
        }

        btn.disabled = true;
        btn.textContent = 'Creating...';

        try {
            var form = new FormData();
            form.append('name', name);
            form.append('description', descEl.value.trim());
            form.append('visibility', visEl.value);

            var res = await fetch('/api/repos', {
                method: 'POST',
                body: form
            });

            if (res.ok) {
                var data = await res.json();
                createdRepoName = data.name;
                document.getElementById('step-1').style.display = 'none';
                document.getElementById('step-2').style.display = 'block';
                errEl.style.display = 'none';
            } else {
                var data = {};
                try { data = await res.json(); } catch(e) {}
                errEl.textContent = data.detail || 'Could not create repository.';
                errEl.style.display = 'block';
                btn.disabled = false;
                btn.textContent = 'Create Repository';
            }
        } catch(err) {
            errEl.textContent = 'Network error.';
            errEl.style.display = 'block';
            btn.disabled = false;
            btn.textContent = 'Create Repository';
        }
    }

    btn.addEventListener('click', doCreate);
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && document.getElementById('step-1').style.display !== 'none') doCreate();
    });
    
    // STEP 2 LOGIC
    dropZone.addEventListener('click', function() { folderInput.click(); });

    dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropZone.style.borderColor = '#58a6ff';
    });
    dropZone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dropZone.style.borderColor = '#30363d';
    });
    dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropZone.style.borderColor = '#30363d';
        if (e.dataTransfer.files.length > 0) handleFiles(e.dataTransfer.files);
    });

    folderInput.addEventListener('change', function() {
        if (this.files.length > 0) handleFiles(this.files);
    });
    
    function handleFiles(files) {
        var ignored = ['__pycache__', '.pyc', '.git', 'node_modules',
                       '.venv', '.DS_Store', 'Thumbs.db', '.olympusrepo'];

        selectedFilteredFiles = Array.from(files).filter(function(f) {
            return !ignored.some(function(pattern) {
                return (f.webkitRelativePath || f.name).includes(pattern);
            });
        });

        if (selectedFilteredFiles.length === 0) {
            showError('No files to upload after filtering.');
            uploadPreview.style.display = 'none';
            uploadFinishBtn.disabled = true;
            return;
        }
        
        errEl.style.display = 'none';
        uploadPreview.style.display = 'block';
        uploadCount.textContent = selectedFilteredFiles.length + ' file(s) selected';
        uploadList.innerHTML = '';
        
        selectedFilteredFiles.forEach(function(f) {
            var div = document.createElement('div');
            div.textContent = f.webkitRelativePath || f.name;
            uploadList.appendChild(div);
        });
        
        uploadFinishBtn.disabled = false;
    }
    
    function showProgress(msg) {
        uploadFinishBtn.textContent = msg;
        uploadFinishBtn.disabled = true;
        skipBtn.disabled = true;
    }

    function showError(msg) {
        errEl.textContent = msg;
        errEl.style.display = 'block';
        uploadFinishBtn.disabled = false;
        uploadFinishBtn.textContent = 'Upload & Finish';
        skipBtn.disabled = false;
    }
    
    skipBtn.addEventListener('click', function() {
        if(createdRepoName) {
            window.location = '/repo/' + encodeURIComponent(createdRepoName);
        }
    });

    uploadFinishBtn.addEventListener('click', async function() {
        var msg = commitMessage.value.trim() || 'Initial commit';
        await doUpload(createdRepoName, selectedFilteredFiles, msg);
    });
    
    async function doUpload(repoName, files, message) {
        var form = new FormData();
        form.append('message', message);
    
        files.forEach(function(f) {
            var path = f.webkitRelativePath || f.name;
            var parts = path.split('/');
            if (parts.length > 1) parts.shift();
            path = parts.join('/');
            form.append('files', f, path);
        });
    
        showProgress('Uploading ' + files.length + ' files...');
    
        try {
            var res = await fetch('/api/repos/' + encodeURIComponent(repoName) + '/upload',
                                  { method: 'POST', body: form });
            if (res.ok) {
                window.location = '/repo/' + encodeURIComponent(repoName);
            } else {
                var data = {};
                try { data = await res.json(); } catch(e) {}
                showError(data.detail || 'Upload failed.');
            }
        } catch(err) {
            showError('Network error during upload.');
        }
    }
})();
</script>
{% endblock %}
